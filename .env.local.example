# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → your project → Settings → API

# Public keys (safe to expose in the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key (server-only — NEVER expose to the browser)
# Used by API routes that need to bypass RLS
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Admin API key ─────────────────────────────────────────────────────────────
# A secret string you make up — the main website sends this header when calling
# your admin API routes (POST /api/listings, PUT /api/listings/:id, DELETE ...)
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_API_KEY=your-secret-api-key-here
